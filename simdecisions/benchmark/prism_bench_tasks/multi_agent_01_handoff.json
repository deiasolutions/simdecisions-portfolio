    {"id": "e6", "from_node": "b_process", "to_node": "b_complete", "type": "then"},
    {"id": "e7", "from_node": "b_complete", "to_node": "end", "type": "then"}
  ],
  "metadata": {
    "category": "multi-agent",
    "description": "Simple handoff from Agent A to Agent B with coordination overhead",
    "evaluation_criteria": "Handoff edge correct, both agents complete work, no data loss at handoff",
