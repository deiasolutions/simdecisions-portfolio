{
  "id": "multi_agent_04_round_robin",
  "name": "Round-Robin Agent Pool",
  "intent": "Test round-robin routing across agent pool for load balancing",
  "phase_ir_version": "1.0.0",
  "variables": [
    {"id": "assignment_index", "type": "counter", "default": 0}
  ],
  "groups": [
    {"id": "dispatcher", "name": "Dispatcher", "node_ids": ["start", "route"]},
    {"id": "pool_1", "name": "Worker Pool 1", "node_ids": ["worker_1"]},
    {"id": "pool_2", "name": "Worker Pool 2", "node_ids": ["worker_2"]},
    {"id": "pool_3", "name": "Worker Pool 3", "node_ids": ["worker_3"]}
  ],
  "nodes": [
    {"id": "start", "type": "start", "name": "Start"},
    {"id": "route", "type": "decision", "name": "Round-Robin Router", "mode": "exclusive"},
    {"id": "worker_1", "type": "service", "name": "Worker 1", "config": {"duration": {"type": "exponential", "params": {"lambda": 1.0}}}},
    {"id": "worker_2", "type": "service", "name": "Worker 2", "config": {"duration": {"type": "exponential", "params": {"lambda": 1.0}}}},
    {"id": "worker_3", "type": "service", "name": "Worker 3", "config": {"duration": {"type": "exponential", "params": {"lambda": 1.0}}}},
    {"id": "end", "type": "sink", "name": "End"}
  ],
  "edges": [
    {"id": "e1", "from_node": "start", "to_node": "route", "type": "then"},
    {"id": "e2", "from_node": "route", "to_node": "worker_1", "type": "switch", "guard": "assignment_index % 3 == 0"},
    {"id": "e3", "from_node": "route", "to_node": "worker_2", "type": "switch", "guard": "assignment_index % 3 == 1"},
    {"id": "e4", "from_node": "route", "to_node": "worker_3", "type": "switch", "guard": "assignment_index % 3 == 2"},
    {"id": "e5", "from_node": "worker_1", "to_node": "end", "type": "then"},
    {"id": "e6", "from_node": "worker_2", "to_node": "end", "type": "then"},
    {"id": "e7", "from_node": "worker_3", "to_node": "end", "type": "then"}
  ],
  "metadata": {
    "category": "multi-agent",
    "description": "Round-robin routing to pool of 3 workers using modulo assignment",
    "evaluation_criteria": "Load balanced evenly across workers, assignment_index increments correctly",
    "expected_runtime_seconds": 5,
    "agent_count": 4,
    "handoff_points": [
      {"from": "dispatcher", "to": "pool_1", "edge": "e2"},
      {"from": "dispatcher", "to": "pool_2", "edge": "e3"},
      {"from": "dispatcher", "to": "pool_3", "edge": "e4"}
    ]
  }
}
