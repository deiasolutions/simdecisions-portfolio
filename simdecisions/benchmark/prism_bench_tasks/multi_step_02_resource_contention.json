{
  "id": "multi_step_02_resource_contention",
  "name": "Resource Contention Workflow",
  "intent": "Test queueing behavior under shared resource constraints",
  "phase_ir_version": "1.0.0",
  "resources": [
    {
      "id": "shared_processor",
      "type": "compute",
      "capacity": 2,
      "queue_discipline": "FIFO"
    }
  ],
  "nodes": [
    {"id": "gen", "type": "source", "name": "Task Generator"},
    {"id": "task1", "type": "service", "name": "Task Step 1", "config": {"duration": {"type": "exponential", "params": {"lambda": 1.0}}, "resource": "shared_processor"}},
    {"id": "task2", "type": "service", "name": "Task Step 2", "config": {"duration": {"type": "exponential", "params": {"lambda": 1.2}}, "resource": "shared_processor"}},
    {"id": "task3", "type": "service", "name": "Task Step 3", "config": {"duration": {"type": "exponential", "params": {"lambda": 1.5}}, "resource": "shared_processor"}},
    {"id": "complete", "type": "sink", "name": "Completion"}
  ],
  "edges": [
    {"id": "e1", "from_node": "gen", "to_node": "task1", "type": "then"},
    {"id": "e2", "from_node": "task1", "to_node": "task2", "type": "then"},
    {"id": "e3", "from_node": "task2", "to_node": "task3", "type": "then"},
    {"id": "e4", "from_node": "task3", "to_node": "complete", "type": "then"}
  ],
  "metadata": {
    "category": "multi-step",
    "description": "Sequential workflow with shared resource bottleneck (capacity 2)",
    "evaluation_criteria": "Resource utilization > 85%, queue wait time tracked, no deadlocks",
    "expected_runtime_seconds": 10,
    "node_count": 5,
    "resource_contention": true
  }
}
