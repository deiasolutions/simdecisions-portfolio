{
  "routes": [
    { "src": "/auth/(.*)", "dest": "https://beneficial-cooperation-production.up.railway.app/auth/$1" },
    { "src": "/token/(.*)", "dest": "https://beneficial-cooperation-production.up.railway.app/token/$1" },
    { "src": "/dev-login/(.*)", "dest": "https://beneficial-cooperation-production.up.railway.app/dev-login/$1" },
    { "src": "/relay/(.*)", "dest": "https://hivenode-production.up.railway.app/relay/$1" },
    { "src": "/api/(.*)", "dest": "https://hivenode-production.up.railway.app/api/$1" },
    { "src": "/llm/(.*)", "dest": "https://hivenode-production.up.railway.app/llm/$1" },
    { "src": "/rag/(.*)", "dest": "https://hivenode-production.up.railway.app/rag/$1" },
    { "src": "/health", "dest": "https://hivenode-production.up.railway.app/health" },
    { "src": "/storage/(.*)", "dest": "https://hivenode-production.up.railway.app/storage/$1" },
    { "src": "/build/(.*)", "dest": "https://hivenode-production.up.railway.app/build/$1" },
    { "src": "/hivenode/(.*)", "dest": "https://hivenode-production.up.railway.app/hivenode/$1" },
    { "src": "/beacon", "dest": "https://hivenode-production.up.railway.app/beacon" },
    { "src": "/games/(.*\\.html)$", "dest": "/games/$1" },
    { "src": "/(.*\\.(js|css|png|jpg|svg|ico|woff2?|ttf|json))$", "dest": "/$1" },
    { "src": "/(.*\\.set\\.md)$", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/hodeia.html", "has": [{ "type": "host", "value": "hodeia.guru" }] },
    { "src": "/(.*)", "dest": "/hodeia.html", "has": [{ "type": "host", "value": "www.hodeia.guru" }] },
    { "src": "/(.*)", "dest": "/hodeia.html", "has": [{ "type": "host", "value": "hodeia.me" }] },
    { "src": "/(.*)", "dest": "/hodeia.html", "has": [{ "type": "host", "value": "www.hodeia.me" }] },
    { "src": "/(.*)", "dest": "/chat-landing.html", "has": [{ "type": "host", "value": "chat.shiftcenter.com" }] },
    { "src": "/blog/?$", "dest": "/blog/index.html", "has": [{ "type": "host", "value": "simdecisions.com" }] },
    { "src": "/blog/?$", "dest": "/blog/index.html", "has": [{ "type": "host", "value": "www.simdecisions.com" }] },
    { "src": "/blog/(.*)", "dest": "/blog/$1.html", "has": [{ "type": "host", "value": "simdecisions.com" }] },
    { "src": "/blog/(.*)", "dest": "/blog/$1.html", "has": [{ "type": "host", "value": "www.simdecisions.com" }] },
    { "src": "/(.*)", "dest": "/simdecisions-landing.html", "has": [{ "type": "host", "value": "simdecisions.com" }] },
    { "src": "/(.*)", "dest": "/simdecisions-landing.html", "has": [{ "type": "host", "value": "www.simdecisions.com" }] },
    { "src": "/(.*)", "dest": "/app.html", "has": [{ "type": "host", "value": "efemera.live" }] },
    { "src": "/(.*)", "dest": "/app.html", "has": [{ "type": "host", "value": "www.efemera.live" }] },
    { "src": "/(.*)", "dest": "/app.html", "has": [{ "type": "host", "value": "shiftcenter.com" }, { "type": "query", "key": "token" }] },
    { "src": "/(.*)", "dest": "/app.html", "has": [{ "type": "host", "value": "www.shiftcenter.com" }, { "type": "query", "key": "token" }] },
    { "src": "/(.*)", "dest": "/app.html", "has": [{ "type": "host", "value": "shiftcenter.com" }, { "type": "query", "key": "set" }] },
    { "src": "/(.*)", "dest": "/app.html", "has": [{ "type": "host", "value": "www.shiftcenter.com" }, { "type": "query", "key": "set" }] },
    { "src": "/(.*)", "dest": "/shiftcenter-landing.html" }
  ],
  "buildCommand": "cd browser && npm run build",
  "outputDirectory": "browser/dist",
  "installCommand": "cd browser && npm install",
  "framework": null
}
